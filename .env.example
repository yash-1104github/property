GEMINI_API_KEY=your-gemini-api-key-here
# When the key is set, enrichment runs if use_llm is true (see USE_LLM).
# USE_LLM=false
# Optional: Regrid Parcel API (https://regrid.com/api) — used when registry lists us_regrid_parcel
REGRID_API_TOKEN=

GOOGLE_GEOCODING_API_KEY=your-key-here
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://user:password@localhost:5432/property_scraper

# Site registry (3000+ portals in DB). Requires backend/infrastructure/sql/site_registry.sql
USE_SITE_DATABASE=false
# If true, append YAML registry sources after DB (deduped)
MERGE_YAML_REGISTRY=false

# Local API — pick one (run from repository root: .../Property)
#   python -m backend
#   cd backend && uvicorn api.main:app --host 0.0.0.0 --port 8000
#   uvicorn api.main:app --app-dir backend --host 0.0.0.0 --port 8000
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=0

# Cook County open data / Treasurer (optional)
# COOK_COUNTY_SOCRATA_APP_TOKEN=
# Headless Playwright often gets no tax bill HTML from cookcountytreasurer.com; try false locally.
# COOK_TREASURER_HEADLESS=false
